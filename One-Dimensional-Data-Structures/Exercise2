
import java.util.*;
import java.util.NoSuchElementException;

 class LinkedQueue<E> implements Queue<E> {

    // Redicata e pretstavena na sledniot nacin:
    // length go sodrzi brojot na elementi.
    // Elementite se zachuvuvaat vo jazli dod SLL
    // front i rear se linkovi do prviot i posledniot jazel soodvetno.
    SLLNode<E> front, rear;
    int length;

    // Konstruktor ...

    public LinkedQueue () {
        clear();
    }

    public boolean isEmpty () {
        // Vrakja true ako i samo ako redicata e prazena.
        return (length == 0);
    }

    public int size () {
        // Ja vrakja dolzinata na redicata.
        return length;
    }

    public E peek () {
        // Go vrakja elementot na vrvot t.e. pocetokot od redicata.
        if (front == null)
            throw new NoSuchElementException();
        return front.element;
    }

    public void clear () {
        // Ja prazni redicata.
        front = rear = null;
        length = 0;
    }

    public void enqueue (E x) {
        // Go dodava x na kraj od redicata.
        SLLNode<E> latest = new SLLNode<E>(x, null);
        if (rear != null) {
            rear.succ = latest;
            rear = latest;
        } else
            front = rear = latest;
        length++;
    }

    public E dequeue () {
        // Go otstranuva i vrakja pochetniot element na redicata.
        if (front != null) {
            E frontmost = front.element;
            front = front.succ;
            if (front == null)  rear = null;
            length--;
            return frontmost;
        } else
            throw new NoSuchElementException();
    }

}


class SLLNode<E> {
    protected E element;
    protected SLLNode<E> succ;

    public SLLNode(E elem, SLLNode<E> succ) {
        this.element = elem;
        this.succ = succ;
    }

    @Override
    public String toString() {
        return element.toString();
    }
}
interface Queue<E> {
    // Elementi na redicata se objekti od proizvolen tip.
    // Metodi za pristap:
    public boolean isEmpty();
    // Vrakja true ako i samo ako redicata e prazena.

    public int size();
    // Ja vrakja dolzinata na redicata.

    public E peek();
    // Go vrakja elementot na vrvot t.e. pocetokot od redicata.

    // Metodi za transformacija:

    public void clear();
    // Ja prazni redicata.

    public void enqueue(E x);
    // Go dodava x na kraj od redicata.

    public E dequeue();
    // Go otstranuva i vrakja pochetniot element na redicata.
}
class Student{
    String ime;
    String nauka;
    String fantastika;
    String istorija;
    public Student(String ime, String nauka, String fantastika, String istorija) {
        this.ime=ime;
        this.nauka=nauka;
        this.fantastika=fantastika;
        this.istorija=istorija;
    }
}

public class zadaca2 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        sc.nextLine();
        LinkedQueue<Student> queue = new LinkedQueue<>();

        LinkedQueue<Student> nauka = new LinkedQueue<>();
        LinkedQueue<Student> fantastika = new LinkedQueue<>();
        LinkedQueue<Student> istorija = new LinkedQueue<>();

        for(int i=0;i<n;i++){
            String ime=sc.nextLine();
            String naukaFlag=sc.nextLine();
            String fantastikaFlag=sc.nextLine();
            String istorijaFlag=sc.nextLine();
            Student s=new Student(ime, naukaFlag, fantastikaFlag, istorijaFlag);
            queue.enqueue(s);
        }
        while(!queue.isEmpty()){
          Student s=queue.dequeue();
          if(s.nauka.equals("1")){
              nauka.enqueue(s);
              continue;
          }
          if(s.fantastika.equals("1")){
              fantastika.enqueue(s);
              continue;
          }
          if(s.istorija.equals("1")){
              istorija.enqueue(s);
          }
        }
        while(!nauka.isEmpty()){
            Student s=nauka.dequeue();
            if(s.fantastika.equals("1")){
                fantastika.enqueue(s);
            }
            else if(s.istorija.equals("1")){
                istorija.enqueue(s);
            }
            else {
                System.out.println(s.ime);
            }
        }
        while(!fantastika.isEmpty()){
            Student s=fantastika.dequeue();
            if(s.istorija.equals("1")){
                istorija.enqueue(s);
            }
            else{
                System.out.println(s.ime);
            }
        }
        while(!istorija.isEmpty()){
            Student s=istorija.dequeue();
            System.out.println(s.ime);
        }
    }
}
