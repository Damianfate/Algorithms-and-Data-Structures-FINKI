        this.ime=ime;
        this.vozrast=vozrast;
    }

    @Override
    public String toString() {
        // имплементирајте го toString методот според барањето во текстот
        // implement the toString method as requested in the text
        return "<"+ime+", "+vozrast+">";
    }


    // имплементирајте ги следните два методи за да работи табелата правилно
    // implement the following two methods to make the table work properly
    @Override
    public boolean equals(Object o) {
        if(this==o)return true;
        if(!(o instanceof Person))return false;
        Person other = (Person)o;
        return this.vozrast==other.vozrast&& this.ime.equals(other.ime);
    }
    @Override
    public int compareTo(Person other) {
        int cmp = this.ime.compareTo(other.ime);
        if (cmp != 0) return cmp;
        return Integer.compare(this.vozrast, other.vozrast);
    }


    @Override
    public int hashCode() {
        return vozrast*(int)ime.charAt(0);
    }
}

