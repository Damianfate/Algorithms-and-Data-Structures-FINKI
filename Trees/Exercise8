import java.util.*;
class BNode {
    int value;
    BNode left, right;
    int size;

    public BNode(int value) {
        this.value = value;
        this.left = null;
        this.right = null;
        this.size = 1;
    }
}


class BinarySearchTree {
    private BNode root;

    public BinarySearchTree() {
        this.root = null;
    }

    public void insert(int value) {
        root = insert(root, value);
    }

    private BNode insert(BNode node, int value) {
        if (node == null) {
            return new BNode(value);
        }

        if (value < node.value) {
            node.left = insert(node.left, value);
        } else {
            node.right = insert(node.right, value);
        }

        node.size = 1 + size(node.left) + size(node.right);
        return node;
    }

    private int size(BNode node) {
        if (node == null) {
            return 0;
        }
        return node.size;
    }

    public int ask(int value) {
        return ask(root, value);
    }

    private int ask(BNode node, int value) {
        if (node == null) {
            return 0;
        }

        if (value < node.value) {
            return 1 + size(node.right) + ask(node.left, value);
        } else {
            return ask(node.right, value);
        }
    }
}


public class zadaca7 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int q = sc.nextInt();
        sc.nextLine();
        BinarySearchTree drvo = new BinarySearchTree();
        for (int i = 0; i < n+q; i++) {
            String komanda = sc.next();
            int value = sc.nextInt();
            if (komanda.equals("insert")) {
                drvo.insert(value);
            } else if (komanda.equals("ask")) {
                System.out.println(drvo.ask(value));
            }
        }

    }

}
