import java.util.*;
public class zadaca4 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int q = sc.nextInt();
        sc.nextLine();
        BTree<String> drvce = new BTree<>();
        Map<String, BNode<String>> hashMap = new HashMap<>();
        for (int i = 0; i < n+q; i++) {
            String delovi[] = sc.nextLine().split(" ");
            if (delovi[0].equals("root")){
                String rootName = delovi[1];
                drvce.makeRoot(rootName);
                hashMap.put(rootName, drvce.root);
            } else if (delovi[0].equals("add")){
                String parentName = delovi[1];
                String childName = delovi[2];
                String side = delovi[3];
                BNode<String> parentNode = hashMap.get(parentName);
                int sideNode = 0;
                if (side.equals("LEFT")) {
                    sideNode = BNode.LEFT;
                } else {
                    sideNode =  BNode.RIGHT;
                }
                hashMap.put(childName,drvce.addChild(parentNode,sideNode,childName));
            } else if(delovi[0].equals("ask")){
                String nodeName = delovi[1];
                BNode<String> nodeche = hashMap.get(nodeName);
                System.out.println(drvce.depthR(nodeche)+1);
            }
        }
    }
}
