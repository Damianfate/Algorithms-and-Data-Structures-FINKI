import java.util.*;

public class zadaca2 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int q = sc.nextInt();
        sc.nextLine();
        BTree<String> btree = new BTree<>(); 
        Map<String, BNode<String>> hash = new HashMap<>();
        for (int i = 0; i < n + q; i++) {
            String line = sc.nextLine();
            String[] delovi = line.split(" ");
            if (delovi[0].equals("root")) {
                String rootName=delovi[1]; 
                btree.makeRoot(rootName); 
                hash.put(rootName, btree.root); 
            }
            else if(delovi[0].equals("add")){
                String parentName=delovi[1]; 
                String childName=delovi[2]; 
                String strana = delovi[3]; 
                BNode<String> parentNode=hash.get(parentName); 
                int side = 0;
                if(strana.equals("LEFT")){
                    side = BNode.LEFT;
                }
                else if(strana.equals("RIGHT")){
                    side = BNode.RIGHT;
                }

                hash.put(childName,btree.addChild(parentNode,side,childName)); 
            }
            else if(delovi[0].equals("ask")){
                String node_name=delovi[1]; 
                BNode<String> askNode = hash.get(node_name);  
                int depth= btree.insideNodesR(askNode);
                System.out.println(depth);
            }
        }


    }

}
