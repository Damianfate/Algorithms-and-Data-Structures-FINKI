import java.util.*;
import java.util.*;

class ArrayStack<E> {
    private E[] element;
    private int depth;

    @SuppressWarnings("unchecked")
    public ArrayStack(int maxDepth) {
        element = (E[]) new Object[maxDepth];
        depth = 0;
    }

    public boolean isEmpty() {
        return depth == 0;
    }

    public E peek() {
        if (isEmpty()) throw new NoSuchElementException();
        return element[depth - 1];
    }

    public void clear() {
        Arrays.fill(element, 0, depth, null);
        depth = 0;
    }

    public void push(E x) {
        element[depth++] = x;
    }

    public E pop() {
        if (isEmpty()) throw new NoSuchElementException();
        E prvo = element[--depth];
        element[depth] = null;
        return prvo;
    }
}

class BNode<E> {
    E info;
    BNode<E> left, right;

    public BNode(E info) {
        this.info = info;
    }
}

class BTree<E extends Comparable<E>> {
    private BNode<E> root;

    public void insert(E value) {
        if (root == null) root = new BNode<>(value);
        else insert(root, value);
    }

    private void insert(BNode<E> node, E value) {
        if (value.compareTo(node.info) < 0) {
            if (node.left == null) node.left = new BNode<>(value);
            else insert(node.left, value);
        } else {
            if (node.right == null) node.right = new BNode<>(value);
            else insert(node.right, value);
        }
    }

    public int depthOfValue(E value) {
        return depthRecursive(root, value, 1);
    }

    private int depthRecursive(BNode<E> node, E value, int depth) {
        if (node == null) return -1;
        if (node.info.equals(value)) return depth;
        return depthRecursive(value.compareTo(node.info) < 0 ? node.left : node.right, value, depth + 1);
    }
}

