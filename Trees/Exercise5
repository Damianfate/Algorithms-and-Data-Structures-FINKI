import java.util.*;


public class zadaca5 {
    public static int sumaNodes(BNode<String> node){
        if(node==null){
            return 0;
        }
        int suma= sumaNodes(node.left)+sumaNodes(node.right);
        if(node.left!=null){
            suma++;
        }
        if(node.right!=null){
            suma++;
        } 
        return suma;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        int q=sc.nextInt();
        sc.nextLine();
        BTree<String> btree=new BTree<>();
        Map<String, BNode<String>>hashMap=new HashMap<>();
        for (int i=0;i<n+q;i++){
            String line=sc.nextLine();
            String [] delovi=line.split(" ");
            if(delovi[0].equals("root")){
                String rootname=delovi[1];
                btree.makeRoot(rootname);
                hashMap.put(rootname, btree.root);
            } else if(delovi[0].equals("add")){
                String parentName=delovi[1];
                String childName=delovi[2];
                String side=delovi[3];
                BNode<String>parentNode=hashMap.get(parentName);
                int strana=0;
                if(side.equals("LEFT")){
                    strana=BNode.LEFT;
                }
                else{
                    strana=BNode.RIGHT;
                }
                hashMap.put(childName, btree.addChild(parentNode,strana,childName));
            }
            else if(delovi[0].equals("ask")){
                String nodeName = delovi[1];
                BNode<String> node = hashMap.get(nodeName);
                System.out.println(sumaNodes(node));
            }
        }
    }

}
